__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.DS_Store
*.log

.venv/
venv/
env/

# Local scratch / Colab artifact bundles
tmp/
artifacts/
*.zip

# Local official-reference binaries. Keep README/source notes in Git.
data/external/official_sources/*.pdf
data/external/official_sources/*.PDF

# Raw OCR inputs/outputs can be large and should be restored from Drive/artifacts.
data/raw/images/**
!data/raw/images/.gitkeep
data/raw/ocr/**
!data/raw/ocr/.gitkeep
data/raw/pdfs/**/*.pdf
data/raw/pdfs/**/*.PDF
!data/raw/pdfs/**/.gitkeep
!data/raw/pdfs/README.md
data/raw/crops/**

# Parsed OCR intermediates are reproducible from OCR artifacts.
data/processed/parsed/**

# Generated pipeline outputs/reports. Keep source/manual review inputs in data/external.
data/processed/*.csv
data/processed/*.parquet
outputs/reports/*
outputs/figures/*
